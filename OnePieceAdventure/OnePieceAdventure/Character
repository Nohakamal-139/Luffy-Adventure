import pygame
import os
from world import World

pygame.init()

# أبعاد الشاشة
WIDTH, HEIGHT = 800, 500
screen = pygame.display.set_mode((WIDTH, HEIGHT))
pygame.display.set_caption("Luffy - One Piece Treasure Cruise Edition")

# --- نظام قراءة وتأمين المسارات الذكي ---
BASE_DIR = os.path.dirname(os.path.abspath(__file__))
PATH_BASE = os.path.join(BASE_DIR, "assets", "luffy_base_sheet.png")
PATH_SKILLS = os.path.join(BASE_DIR, "assets", "luffy_skills_sheet.png")

# تحميل ملف الخلفية الجديد الخاص بكِ
PATH_BACKGROUND = os.path.join(BASE_DIR, "assets", "level1.tmx")

if not os.path.exists(PATH_BASE):
    PATH_BASE = os.path.join(BASE_DIR, "assets", "luffy_base_sheet.jpg")
if not os.path.exists(PATH_SKILLS):
    PATH_SKILLS = os.path.join(BASE_DIR, "assets", "luffy_skills_sheet.jpg")

try:
    sheet_base = pygame.image.load(PATH_BASE).convert_alpha()
    sheet_skills = pygame.image.load(PATH_SKILLS).convert_alpha()
    
    # تحميل صورة الخلفية level1.tmx
    background_img = pygame.image.load(PATH_BACKGROUND).convert()
    # جعل الخلفية متناسبة تماماً مع أبعاد شاشة اللعبة
    background_img = pygame.transform.scale(background_img, (WIDTH, HEIGHT))
except pygame.error as e:
    print(f"خطأ في تحميل الصور! تأكد من مجلد assets والصور: {e}")
    pygame.quit()
    exit()

# حجم عرض لوفي الموحد المناسب للشاشة
SIZE = (130, 150)

def get_frame(sheet, x, y, w, h):
    """دالة التقطيع الآمنة مع تفريغ الخلفية السوداء بشكل تام وتكبير الحجم بالتساوي"""
    sub = sheet.subsurface((int(x), int(y), int(w), int(h))).copy()
    sub.set_colorkey((0, 0, 0))  # إزالة اللون الأسود
    return pygame.transform.scale(sub, SIZE)

# --- إحداثيات معدلة بالكامل بناءً على التجربة الأخيرة لمنع ظهور أي زوائد ---

# 1. حركة الوقوف (Idle)
idle_frames = [
    get_frame(sheet_base, 10, 85, 105, 185),
    get_frame(sheet_base, 140, 85, 105, 185),
    get_frame(sheet_base, 270, 85, 105, 185),
    get_frame(sheet_base, 400, 85, 105, 185),
    get_frame(sheet_base, 530, 85, 105, 185)
]

# 2. حركة الجري (Run)
run_frames = [
    get_frame(sheet_base, 660, 85, 120, 185),
    get_frame(sheet_base, 790, 85, 125, 185),
    get_frame(sheet_base, 10, 310, 125, 185),
    get_frame(sheet_base, 170, 310, 125, 185)
]

# 3. حركة القفز (Jump)
jump_frames = [
    get_frame(sheet_base, 20, 535, 110, 135),
    get_frame(sheet_base, 150, 535, 110, 135)
]

# 4. حركة اللكمة العادية الأولى (Attack 1 - زر X)
attack_frames = [
    get_frame(sheet_skills, 35, 65, 110, 180),
    get_frame(sheet_skills, 235, 65, 110, 180),
    get_frame(sheet_skills, 435, 65, 110, 180)
]

# الحركة القتالية الزائدة الجديدة (Combo / Attack 2 - زر V)
special_combo_frames = [
    get_frame(sheet_skills, 15, 485, 120, 180),
    get_frame(sheet_skills, 145, 485, 130, 180),
    get_frame(sheet_skills, 285, 485, 150, 180)
]

# 5. ضربة اللكمات السريعة (Gatling - زر Z)
gatling_frames = [
    get_frame(sheet_skills, 285, 275, 140, 180),
    get_frame(sheet_skills, 425, 275, 140, 180)
]

# 6. ضربة اليد الطويلة الممتدة (Gum-Gum Pistol - زر C)
gum_gum_frames = [
    get_frame(sheet_skills, 10, 970, 245, 185),
    get_frame(sheet_skills, 710, 1170, 265, 185)
]

# متغيرات الحركات والأنيميشن التلقائي
current_state = "idle"
frame_index = 0
animation_speed = 0.15  
facing_left = False

# --- ⚔️ نظام عداد الكومبو والضربات الجديد لليدر ---
attack1_hit_count = 0        
combo_ready = False          
attack_already_registered = False 

# إحداثيات وميكانيكا اللاعب
player_x = 100
player_y = 280
speed = 6

velocity_y = 0
gravity = 0.6
jump_power = -14
ground = 280
on_ground = True

clock = pygame.time.Clock()
running = True

# حلقة اللعبة (Game Loop)
while running:
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            running = False

    keys = pygame.key.get_pressed()
    new_state = "idle"

    # حركة الجري والاتجاهات
    if keys[pygame.K_RIGHT]:
        player_x += speed
        new_state = "run"
        facing_left = False
    elif keys[pygame.K_LEFT]:
        player_x -= speed
        new_state = "run"
        facing_left = True

    # حماية من الخروج عن الشاشة
    if player_x < 0: player_x = 0
    if player_x > WIDTH - SIZE[0]: player_x = WIDTH - SIZE[0]

    # ميكانيكية القفز
    if keys[pygame.K_SPACE] and on_ground:
        velocity_y = jump_power
        on_ground = False

    # تفعيل المهارات والضربات
    if keys[pygame.K_x]:       
        new_state = "attack"
    elif keys[pygame.K_v] and combo_ready: 
        new_state = "special_combo"
    elif keys[pygame.K_z]:     
        new_state = "gatling"
    elif keys[pygame.K_c]:     
        new_state = "gum_gum"

    # نظام الفيزياء والجاذبية للقفز
    velocity_y += gravity
    player_y += velocity_y

    if player_y >= ground:
        player_y = ground
        velocity_y = 0
        on_ground = True
    else:
        if new_state not in ["attack", "special_combo", "gatling", "gum_gum"]:
            new_state = "jump"

    if new_state != current_state:
        current_state = new_state
        frame_index = 0
        attack_already_registered = False 

    # اختيار مصفوفة العرض النشطة
    if current_state == "idle": active_list = idle_frames
    elif current_state == "run": active_list = run_frames
    elif current_state == "jump": active_list = jump_frames
    elif current_state == "attack": active_list = attack_frames
    elif current_state == "special_combo": active_list = special_combo_frames
    elif current_state == "gatling": active_list = gatling_frames   
    elif current_state == "gum_gum": active_list = gum_gum_frames   

    # تحديث مؤشر الفريمات
    frame_index += animation_speed
    
    # محاكاة ضرب العدو
    if current_state == "attack" and int(frame_index) == 1 and not attack_already_registered:
        attack1_hit_count += 1
        attack_already_registered = True
        print(f"🎯 ضربة ناجحة! العداد الحالي: {attack1_hit_count}/2")
        if attack1_hit_count >= 2:
            combo_ready = True
            print("🔥 الحركة القتالية الإضافية جاهزة الآن! اضغط على زر [ V ] لتنفيذها!")

    if frame_index >= len(active_list):
        if current_state in ["attack", "special_combo", "gatling", "gum_gum"]:
            if current_state == "special_combo":
                attack1_hit_count = 0
                combo_ready = False
                print("✨ تم تنفيذ الحركة المجمعة بنجاح، تم إعادة تصدير العداد.")
            
            current_state = "idle"
            frame_index = 0
            active_list = idle_frames
        else:
            frame_index = 0

    current_image = active_list[int(frame_index)]

    if facing_left:
        current_image = pygame.transform.flip(current_image, True, False)

    # --- تم إزالة الألوان القديمة ورسم ملف level1.tmx الجديد مكانه هنا بالظبط ---
    screen.blit(background_img, (0, 0))

    # مؤشر بصري على الشاشة لمعرفة حالة حركة الكومبو
    if combo_ready:
        font = pygame.font.SysFont(None, 30)
        text = font.render("COMBO READY! Press V", True, (255, 69, 0))
        screen.blit(text, (20, 20))

    # رسم شخصية لوفي
    screen.blit(current_image, (player_x, player_y))

    pygame.display.update()
    clock.tick(60)

pygame.quit()